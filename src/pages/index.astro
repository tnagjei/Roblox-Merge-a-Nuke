---
import SiteLayout from "../layouts/SiteLayout.astro";
import HomeHero from "../components/HomeHero.astro";
import { homeContent } from "../content/home";
import { siteConfig } from "../data/config";
import { gameData } from "../data/game";
import { evidenceNotice, reportedCodeRows } from "../data/reported-guides";
import { jsonLd } from "../lib/seo";

const completedGuideLinks = homeContent.wikiLinks.filter((link) => siteConfig.completedCoreSlugs.includes(link.slug));
const showReportedCodeWatch = siteConfig.completedCoreSlugs.includes("codes");
---

<SiteLayout title={homeContent.title} description={homeContent.description}>
  <main>
    <HomeHero />

    {completedGuideLinks.length > 0 && (
      <section class="section" aria-labelledby="wiki-entry">
        <p class="eyebrow">Wiki index</p>
        <h2 id="wiki-entry">Core guide entrances</h2>
        <div class="card-grid hub-grid">
          {completedGuideLinks.map((link) => (
            <a class="card hub-card" href={`/${link.slug}/`}>
              <h3>{link.title}</h3>
              <p>{link.description}</p>
              <span>Open {link.title}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="section grid-section" aria-labelledby="quick-facts">
      <div>
        <p class="eyebrow">Quick facts</p>
        <h2 id="quick-facts">Launch facts</h2>
        <p>Use this hub to publish only the pages that pass source and static export checks.</p>
      </div>
      <div class="card-grid">
        {homeContent.quickFacts.map((fact) => (
          <article class="card">
            <h3>{fact.label}</h3>
            <p>{fact.value}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" aria-labelledby="trending-searches">
      <p class="eyebrow">Trending searches</p>
      <h2 id="trending-searches">Search demand map</h2>
      <div class="tag-list">
        {homeContent.trendingSearches.map((query) => <span>{query}</span>)}
      </div>
    </section>

    {showReportedCodeWatch && (
      <section class="section grid-section" aria-labelledby="reported-code-watch">
        <div>
          <p class="eyebrow">Code watch</p>
          <h2 id="reported-code-watch">Official-page and community signals</h2>
          <p>Official listing text, third-party pages, and in-game redemption checks stay separated.</p>
        </div>
        <div class="card-grid">
          {reportedCodeRows.length > 0 ? (
            reportedCodeRows.map((row) => (
              <article class="card">
                <h3>{row.code}</h3>
                <p>{row.reward}</p>
                <p class="source-label">{row.sourceLabel}</p>
              </article>
            ))
          ) : (
            <p class="empty-state">No community-reported code rows are recorded yet.</p>
          )}
        </div>
      </section>
    )}

    <section class="section" aria-labelledby="guide-map">
      <p class="eyebrow">Guide map</p>
      <h2 id="guide-map">Evidence-first publishing flow</h2>
      <div class="card-grid">
        {homeContent.guideMap.map((item) => (
          <article class="card">
            <p class="eyebrow">Step {item.step}</p>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" aria-labelledby="source-status">
      <p class="eyebrow">Evidence boundaries</p>
      <h2 id="source-status">{evidenceNotice.title}</h2>
      <p>{evidenceNotice.body}</p>
      <ul class="status-list">
        {gameData.sourceConfidence.map((item) => (
          <li><strong>{item.label}</strong><span>{item.level}</span></li>
        ))}
      </ul>
    </section>

    <section class="section" aria-labelledby="faq">
      <p class="eyebrow">FAQ</p>
      <h2 id="faq">Template FAQ</h2>
      <div class="faq-list">
        {homeContent.faq.map((item) => (
          <article>
            <h3>{item.q}</h3>
            <p>{item.a}</p>
          </article>
        ))}
      </div>
    </section>
    <script type="application/ld+json" set:html={jsonLd({
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: homeContent.title,
      description: homeContent.description
    })} />
  </main>
</SiteLayout>
