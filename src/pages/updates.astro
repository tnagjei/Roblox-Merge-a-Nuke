---
import SiteLayout from "../layouts/SiteLayout.astro";
import RelatedGuides from "../components/RelatedGuides.astro";
import { siteConfig } from "../data/config";
import { gameData } from "../data/game";
---

<SiteLayout title={`Updates | ${siteConfig.siteName}`} description={`Update tracker for ${siteConfig.gameName} with confirmed cadence and pending patch details.`}>
  <main class="content-page">
    <section class="prose-block" style="margin-bottom: 40px;">
      <p class="eyebrow">Updates</p>
      <h1>{siteConfig.gameName} Updates</h1>
      <p>{gameData.updateCadence}</p>
      <p class="source-label">Patch-note detail status: pending. Do not treat video titles or third-party posts as official patch notes.</p>
    </section>

    <section class="section" aria-labelledby="update-log" style="margin-bottom: 48px;">
      <p class="eyebrow">Update log</p>
      <h2 id="update-log" style="margin-bottom: 32px;">Reviewed timeline</h2>
      
      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-marker" style="font-size: 0.65rem; border-color: var(--accent); color: var(--accent);">LOG</div>
          <div style="padding-left: 12px;">
            <h3 style="color: var(--accent);">2026-06-16 Source Check</h3>
            <p style="margin-bottom: 0;">Roblox listing reports Friday updates. Public sources show recent code and gameplay coverage, but no official patch-note body has been verified here.</p>
          </div>
        </div>
        
        <div class="timeline-item">
          <div class="timeline-marker" style="font-size: 0.65rem; border-color: var(--muted); color: var(--muted);">ACT</div>
          <div style="padding-left: 12px;">
            <h3 style="color: var(--text);">Next Action</h3>
            <p style="margin-bottom: 0;">Recheck the Roblox listing, official group channels, and in-game notices after the next Friday update window.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section grid-section" aria-labelledby="update-rules" style="margin-bottom: 48px;">
      <div>
        <p class="eyebrow">Publishing rule</p>
        <h2 id="update-rules">What can be promoted</h2>
      </div>
      <div class="card-grid">
        <article class="card">
          <h3 style="color: var(--accent);">Allowed</h3>
          <p style="margin-bottom: 0;">Official Roblox listing changes, official group posts, in-game notices, and verified screenshots.</p>
        </article>
        <article class="card">
          <h3 style="color: var(--accent);">Not enough alone</h3>
          <p style="margin-bottom: 0;">YouTube titles, Reddit posts, and third-party code pages are signals until cross-checked.</p>
        </article>
      </div>
    </section>

    <RelatedGuides currentSlug="updates" />
  </main>
</SiteLayout>
