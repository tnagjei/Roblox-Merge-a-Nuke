---
// input: SERP calculator page data, shared guide renderer, event tracker
// output: Offline cash calculator page with player-input estimates and evidence-safe guide content
// pos: src/pages/calculator.astro (更新规则：文件变更需同步本注释与所属目录 README)

import SerpGuidePage from "../components/SerpGuidePage.astro";
import ToolEventTracker from "../components/ToolEventTracker.astro";
import { serpPages } from "../data/serp-pages";

const page = serpPages.calculator;
---

<SerpGuidePage page={page}>
  <Fragment slot="feature">
    <section class="section tool-panel" aria-labelledby="offline-cash" style="margin-bottom: 48px;">
      <div>
        <p class="eyebrow">Offline cash planner</p>
        <h2 id="offline-cash">Estimate Your Next Upgrade Window</h2>
        <p style="margin-bottom: 24px;">
          Enter your current cash rate from the game screen, the time you expect to be away, and your target upgrade cost. Every result is labeled estimated because the game does not publish a hidden official formula here.
        </p>
      </div>

      <div class="card" style="background: rgba(18, 22, 32, 0.65); border-color: var(--line); border-radius: var(--radius-card);">
        <form class="calculator-form" data-tool-form>
          <label>
            Cash per minute
            <input id="cash-rate" data-tool-input name="cash_rate" type="number" min="0" step="1" value="0" inputmode="decimal" placeholder="e.g. 500" style="border-radius: var(--radius-interactive);" />
          </label>
          <label>
            Offline minutes
            <input id="offline-minutes" data-tool-input name="offline_minutes" type="number" min="0" step="1" value="60" inputmode="decimal" placeholder="e.g. 60" style="border-radius: var(--radius-interactive);" />
          </label>
          <label>
            Target upgrade cost
            <input id="target-cost" data-tool-input name="target_cost" type="number" min="0" step="1" value="0" inputmode="decimal" placeholder="e.g. 25000" style="border-radius: var(--radius-interactive);" />
          </label>

          <div class="hud-panel" style="border-radius: var(--radius-interactive); padding: 20px; border: 1px solid rgba(30, 144, 255, 0.25);">
            <div class="hud-header" style="margin-bottom: 12px; border-bottom: 1px solid var(--line); padding-bottom: 8px;">
              <span class="hud-dot red"></span>
              <span class="hud-dot yellow"></span>
              <span class="hud-dot green"></span>
              <span style="font-size: 0.72rem; color: var(--color-blue); margin-left: auto; font-family: var(--font-display); font-weight: 800; letter-spacing: 0.05em;">ESTIMATED REPORT</span>
            </div>
            <output class="result-card" id="calculator-result" data-tool-result aria-live="polite" style="display: block; width: 100%; border: none; background: transparent; padding: 0; box-shadow: none; font-family: var(--font-body); font-size: 0.95rem; color: var(--text);">
              Enter your in-game numbers to estimate progress.
            </output>
          </div>
        </form>
      </div>
      <ToolEventTracker toolName="offline_cash_calculator" />
    </section>
  </Fragment>
</SerpGuidePage>

<script>
  const rate = document.querySelector("#cash-rate");
  const minutes = document.querySelector("#offline-minutes");
  const target = document.querySelector("#target-cost");
  const result = document.querySelector("#calculator-result");

  function numericValue(input) {
    return input instanceof HTMLInputElement ? Number(input.value || 0) : 0;
  }

  function formatNumber(value) {
    return new Intl.NumberFormat("en-US", { maximumFractionDigits: 0 }).format(Math.max(0, value));
  }

  function updateCalculator() {
    const estimatedCash = numericValue(rate) * numericValue(minutes);
    const remaining = numericValue(target) - estimatedCash;
    if (!result) return;

    if (numericValue(rate) <= 0 && numericValue(target) <= 0) {
      result.innerHTML = `<span style="color: var(--muted); font-size: 0.9rem;">Waiting for player-input estimate values...</span>`;
      return;
    }

    const formattedEstimated = formatNumber(estimatedCash);
    const formattedRemaining = formatNumber(remaining);

    if (remaining <= 0) {
      result.innerHTML = `
        <div style="color: var(--color-green); margin-bottom: 10px; font-family: var(--font-display); font-weight: 900; font-size: 0.85rem; letter-spacing: 0.05em;">[ ESTIMATED TARGET MET ]</div>
        <div style="font-size: 0.92rem; color: var(--muted);">ESTIMATED CASH INCOME</div>
        <div style="font-size: 1.8rem; font-family: var(--font-mono); font-weight: 800; color: var(--color-green); line-height: 1.2; margin-top: 4px;">$${formattedEstimated}</div>
        <div style="margin-top: 12px; font-size: 0.85rem; color: var(--color-green);">
          This player-input estimate covers the target. Recheck in game before spending.
        </div>
      `;
    } else {
      result.innerHTML = `
        <div style="color: var(--color-red); margin-bottom: 10px; font-family: var(--font-display); font-weight: 900; font-size: 0.85rem; letter-spacing: 0.05em;">[ ESTIMATED GAP ]</div>
        <div style="font-size: 0.92rem; color: var(--muted);">ESTIMATED CASH INCOME</div>
        <div style="font-size: 1.5rem; font-family: var(--font-mono); font-weight: 800; color: var(--text); line-height: 1.2; margin-top: 4px;">$${formattedEstimated}</div>
        <div style="margin-top: 10px; border-top: 1px dashed var(--line); padding-top: 10px; font-size: 0.85rem;">
          ESTIMATED GAP: <span style="color: var(--color-red); font-family: var(--font-mono); font-weight: 700;">$${formattedRemaining}</span>
        </div>
      `;
    }
  }

  for (const input of [rate, minutes, target]) {
    input?.addEventListener("input", updateCalculator);
  }

  updateCalculator();
</script>
