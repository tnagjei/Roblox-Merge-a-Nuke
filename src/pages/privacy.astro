---
// input: systemPageContent for privacy page context
// output: Static privacy policy page rendering from system config
// pos: src/pages/privacy.astro (更新规则：文件变更需同步本注释与所属目录 README)

import SiteLayout from "../layouts/SiteLayout.astro";
import { systemPageContent } from "../content/system-pages";

const page = systemPageContent.privacy;
---

<SiteLayout title={page.title} description={page.description} noindex>
  <main class="content-page">
    <section class="prose-block">
      <p class="eyebrow">Privacy</p>
      <h1>{page.title}</h1>
      {page.sections.map((section) => (
        <>
          <h2>{section.heading}</h2>
          <p>{section.body}</p>
        </>
      ))}
    </section>
  </main>
</SiteLayout>
