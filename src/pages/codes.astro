---
// input: SERP codes page data, reportedCodeRows stream, CopyButton component
// output: Codes page with reported status table, source conflicts, nocookie video, and FAQ
// pos: src/pages/codes.astro (更新规则：文件变更需同步本注释与所属目录 README)

import SerpGuidePage from "../components/SerpGuidePage.astro";
import CopyButton from "../components/CopyButton.astro";
import { reportedCodeRows } from "../data/reported-guides";
import { serpPages } from "../data/serp-pages";

const page = serpPages.codes;
---

<SerpGuidePage page={page}>
  <Fragment slot="feature">
    <section class="section" style="margin-bottom: 48px;">
      <p class="eyebrow">Reported code watch</p>
      <h2 style="margin-bottom: 24px;">Reported Code Watch</h2>
      <p style="margin-bottom: 20px;">Status summary: 0 verified active codes by this site. Copy buttons are provided for reported checks, not as proof that a reward is active.</p>
      <div style="display: grid; gap: 20px;">
        {reportedCodeRows.length > 0 ? (
          reportedCodeRows.map((row) => {
            const isDisputed = row.status === "disputed";
            const isPending = row.status === "community-reported";
            return (
              <article class="card hud-panel" style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 20px; padding: 24px; border-color: rgba(255, 165, 2, 0.25); border-radius: var(--radius-card);">
                <div style="flex: 1; min-width: 250px;">
                  <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px; flex-wrap: wrap;">
                    <span style="color: var(--color-yellow); font-weight: 900; font-family: var(--font-display); font-size: 1.5rem; text-shadow: 0 0 10px rgba(255, 165, 2, 0.35); letter-spacing: 0.02em;">
                      {row.code}
                    </span>
                    <span class={`status-badge ${isDisputed || isPending ? "pending" : ""}`}>
                      {row.status}
                    </span>
                  </div>
                  <p style="margin: 0; font-size: 0.95rem; color: var(--text);">Reward status: <strong style="color: var(--color-green); font-family: var(--font-mono);">{row.reward}</strong></p>
                  <p class="source-label" style="margin-top: 6px; margin-bottom: 0;">{row.sourceLabel}</p>
                </div>
                <div>
                  <CopyButton
                    value={row.code}
                    label="Copy reported code"
                    class="button primary"
                    eventSource="codes_page"
                    itemType="roblox_code"
                    itemName={row.code}
                  />
                </div>
              </article>
            );
          })
        ) : (
          <p class="empty-state">No code rows are published yet because none are verified or ready to record.</p>
        )}
      </div>
    </section>
  </Fragment>
</SerpGuidePage>
