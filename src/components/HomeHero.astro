---
import { siteConfig } from "../data/config";
import { gameData } from "../data/game";
import { homeContent } from "../content/home";

const publicPageCount = siteConfig.routePolicy.publicPaths.length;
---

<section class="hero">
  <div class="hero-copy">
    <p class="eyebrow">{homeContent.hero.eyebrow}</p>
    <h1>{homeContent.hero.title}</h1>
    <p>{homeContent.hero.lede}</p>
    <div class="hero-actions">
      <a class="button primary" href={gameData.robloxUrl} target="_blank" rel="noopener noreferrer">
        {homeContent.hero.primaryAction}
      </a>
      <a class="button secondary" href="/privacy/">Review privacy</a>
    </div>
  </div>
  <div class="hero-card terminal-panel" aria-label="Site status">
    <div class="terminal-header">
      <span class="terminal-dot red"></span>
      <span class="terminal-dot yellow"></span>
      <span class="terminal-dot green"></span>
      <span style="font-size: 0.75rem; color: var(--muted); margin-left: auto; font-family: monospace;">nuke-sys-monitor.sh</span>
    </div>
    <img src={siteConfig.assets.hero} alt={`${siteConfig.siteName} hero art`} loading="eager" />
    <dl>
      <div><dt>Base Defense</dt><dd><span class="status-badge">SHIELD ACTIVE</span></dd></div>
      <div><dt>Deployment</dt><dd>Astro Static</dd></div>
      <div><dt>Guide Pages</dt><dd>{publicPageCount} verified</dd></div>
    </dl>
  </div>
</section>
