---
// input: Site configurations (siteConfig), game data (gameData), homepage text content (homeContent)
// output: Redesigned competitor-inspired hero section with left copy and right game snapshot telemetry card
// pos: src/components/HomeHero.astro (更新规则：文件变更需同步本注释与所属目录 README)

import { gameData } from "../data/game";
import { homeContent } from "../content/home";
import { siteConfig } from "../data/config";

const publicPageCount = siteConfig.routePolicy.publicPaths.length;
---

<section class="hero home-hero">
  <div class="container hero-layout">
    <div class="hero-copy">
      <p class="hero-kicker">{homeContent.hero.eyebrow}</p>
      <h1>{homeContent.hero.title}</h1>
      <p class="hero-lead">{homeContent.hero.lede}</p>
      <div class="cta-row hero-cta">
        <a class="button primary" href="/codes/">Merge a Nuke Codes</a>
        <a class="button accent" href="/beginner-guide/">Beginner Guide</a>
        <a class="button secondary" href={gameData.robloxUrl} target="_blank" rel="noopener noreferrer">Play on Roblox</a>
      </div>
    </div>
    <aside class="snapshot-card" aria-label="Merge a Nuke game snapshot">
      <div class="snapshot-heading">
        <span class="snapshot-mark" aria-hidden="true">🚀</span>
        <div>
          <h2>Game Snapshot</h2>
          <p>Game details checked 2026.</p>
        </div>
      </div>
      <div class="snapshot-grid">
        <div class="snapshot-stat">
          <span class="snapshot-stat-title">Total Visits</span>
          <strong>9.1M+</strong>
          <span class="snapshot-stat-label">Roblox universe visits</span>
        </div>
        <div class="snapshot-stat">
          <span class="snapshot-stat-title">Active Players</span>
          <strong>24.7K</strong>
          <span class="snapshot-stat-label">Players online at last check</span>
        </div>
        <div class="snapshot-stat">
          <span class="snapshot-stat-title">Likes / Favorites</span>
          <strong>46.9K / 86K</strong>
          <span class="snapshot-stat-label">Community signal</span>
        </div>
        <div class="snapshot-stat">
          <span class="snapshot-stat-title">Community Members</span>
          <strong>321K+</strong>
          <span class="snapshot-stat-label">Nuke The Game group</span>
        </div>
        <div class="snapshot-stat">
          <span class="snapshot-stat-title">Last Update</span>
          <strong>Jun 10</strong>
          <span class="snapshot-stat-label">Friday update window</span>
        </div>
        <div class="snapshot-stat">
          <span class="snapshot-stat-title">Public Pages</span>
          <strong>{publicPageCount}</strong>
          <span class="snapshot-stat-label">Indexable route policy</span>
        </div>
      </div>
    </aside>
  </div>
</section>
