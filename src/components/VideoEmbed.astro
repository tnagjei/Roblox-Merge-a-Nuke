---
// input: YouTube embed metadata from SERP execution data
// output: Privacy-enhanced responsive video block with fallback link
// pos: src/components/VideoEmbed.astro (更新规则：文件变更需同步本注释与所属目录 README)

interface Props {
  heading: string;
  title: string;
  embedUrl: string;
  originalUrl: string;
  note: string;
}

const { heading, title, embedUrl, originalUrl, note } = Astro.props;
---

<section class="section video-section" aria-labelledby={heading.toLowerCase().replace(/[^a-z0-9]+/g, "-")}>
  <h2 id={heading.toLowerCase().replace(/[^a-z0-9]+/g, "-")}>{heading}</h2>
  <p>{note}</p>
  <div class="video-frame">
    <iframe
      src={embedUrl}
      title={title}
      loading="lazy"
      allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      allowfullscreen
    ></iframe>
  </div>
  <p class="source-label">
    Video evidence label: youtube_embed. This video is a visual reference, not proof of rewards, formulas, codes, or best routes.
    <a href={originalUrl} target="_blank" rel="noopener noreferrer">Open fallback video</a>.
  </p>
</section>

<style>
  .video-section {
    margin-bottom: 48px;
  }

  .video-section h2 {
    margin-bottom: 16px;
  }

  .video-section p {
    max-width: 820px;
    line-height: 1.65;
  }

  .video-frame {
    width: 100%;
    max-width: 860px;
    aspect-ratio: 16 / 9;
    margin: 24px 0 14px;
    border: 1px solid var(--line);
    border-radius: var(--radius-card);
    overflow: hidden;
    background: rgba(18, 22, 32, 0.72);
  }

  .video-frame iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .source-label a {
    color: var(--color-yellow);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
