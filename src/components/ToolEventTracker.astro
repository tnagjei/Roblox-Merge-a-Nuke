---
// input: toolName, eventSource, inputSelector, resultSelector, inputEventName, resultEventName, debounceMs props
// output: Client-side tracking component for logging tool input interactions and metrics
// pos: src/components/ToolEventTracker.astro (更新规则：文件变更需同步本注释与所属目录 README)

interface Props {
  toolName: string;
  eventSource?: string;
  inputSelector?: string;
  resultSelector?: string;
  inputEventName?: string;
  resultEventName?: string;
  debounceMs?: number;
}

const {
  toolName,
  eventSource = "tool",
  inputSelector = "[data-tool-input]",
  resultSelector = "[data-tool-result]",
  inputEventName = "tool_input_change",
  resultEventName = "tool_result_view",
  debounceMs = 1000
} = Astro.props;
---

<script define:vars={{ toolName, eventSource, inputSelector, resultSelector, inputEventName, resultEventName, debounceMs }}>
  function debounce(callback, wait) {
    let timeoutId;
    return (...args) => {
      window.clearTimeout(timeoutId);
      timeoutId = window.setTimeout(() => callback(...args), wait);
    };
  }

  function trackEvent(name, params) {
    if (typeof window.gtag === "function") {
      window.gtag("event", name, params);
      return;
    }
    if (!window.location.hostname.includes("localhost") && window.location.hostname !== "127.0.0.1") return;
    console.debug("[analytics]", name, params);
  }

  const trackInput = debounce((fieldName) => {
    trackEvent(inputEventName, {
      page_path: window.location.pathname,
      event_source: eventSource,
      tool_name: toolName,
      field_name: fieldName
    });
  }, debounceMs);

  document.querySelectorAll(inputSelector).forEach((input) => {
    if (input.dataset.analyticsInputBound === "true") return;
    input.dataset.analyticsInputBound = "true";

    input.addEventListener("input", () => {
      trackInput(input.getAttribute("name") || input.getAttribute("data-field-name") || "tool_input");
    });
  });

  const result = document.querySelector(resultSelector);
  if (result && result.dataset.analyticsResultViewed !== "true") {
    result.dataset.analyticsResultViewed = "true";
    trackEvent(resultEventName, {
      page_path: window.location.pathname,
      event_source: eventSource,
      tool_name: toolName
    });
  }
</script>
