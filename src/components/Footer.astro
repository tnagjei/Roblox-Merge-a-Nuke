---
// input: siteConfig configurations
// output: Site footer layout component displaying configurable copyright and contact email info
// pos: src/components/Footer.astro (更新规则：文件变更需同步本注释与所属目录 README)

import { siteConfig } from "../data/config";
---

<footer class="site-footer">
  <div class="footer-grid">
    <!-- Col 1: Brand & Contact -->
    <div class="footer-col">
      <strong style="color: var(--color-yellow); font-family: var(--font-display); font-size: 1.25rem; font-weight: 900; letter-spacing: 0.05em; text-shadow: 0 0 10px rgba(255,165,2,0.3);">{siteConfig.siteName}</strong>
      <p style="font-size: 0.9rem; line-height: 1.5; color: var(--muted); margin: 0;">
        Your independent third-party resource hub for Roblox Merge a Nuke strategy guides, active code watch updates, and multiplier walkthrough checklists.
      </p>
      <p style="font-size: 0.85rem; color: var(--muted); margin: 0;">
        Contact support: <a href={`mailto:${siteConfig.contactEmail}`} style="color: var(--accent); text-decoration: none; border-bottom: 1px dashed var(--accent); padding: 0 0 1px;">{siteConfig.contactEmail}</a>
      </p>
    </div>

    <!-- Col 2: Core Tools -->
    <div class="footer-col">
      <h4>Core Tools</h4>
      <ul>
        <li><a href="/">Home Dashboard</a></li>
        <li><a href="/calculator/">Offline Calculator</a></li>
        <li><a href="/codes/">Codes & Payouts</a></li>
        <li><a href="/tier-list/">Weapon Tier List</a></li>
      </ul>
    </div>

    <!-- Col 3: Wiki Sections -->
    <div class="footer-col">
      <h4>Wiki Database</h4>
      <ul>
        <li><a href="/wiki/">Wiki Hub Page</a></li>
        <li><a href="/beginner-guide/">Beginner Loop Guide</a></li>
        <li><a href="/progression/">Progression Speedrun</a></li>
        <li><a href="/raid/">Raid & Shield PvP</a></li>
        <li><a href="/upgrades/">Upgrades Priority</a></li>
        <li><a href="/offline-cash/">Offline Income Setup</a></li>
        <li><a href="/rebirth/">Rebirth Mechanics</a></li>
        <li><a href="/updates/">Updates Changelog</a></li>
      </ul>
    </div>

    <!-- Col 4: Site Policy -->
    <div class="footer-col">
      <h4>Information</h4>
      <ul>
        <li><a href="/about/">About</a></li>
        <li><a href="/contact/">Contact</a></li>
        <li><a href="/editorial-policy/">Editorial Policy</a></li>
        <li><a href="/privacy/">Privacy</a></li>
        <li><a href="/terms/">Terms</a></li>
      </ul>
    </div>
  </div>

  <!-- Featured Partners Scrolling Marquee -->
  <div class="footer-marquee-section">
    <div class="marquee-label">Featured & Partners</div>
    <div class="marquee-container">
      <div class="marquee-track">
        <div class="marquee-group">
          <a href="https://aijustbetter.com/item/mergeanuke.online" target="_blank" rel="noopener" title="Merge a Nuke Guide: Detailed review, analysis and comparison on AI Just Better">
            <img src="https://cdn.aijustbetter.com/badges/badge-dark.svg" alt="Featured on AIJustBetter.com" width="212" height="55" />
          </a>
          <a href="https://aiblog.tools" target="_blank" class="marquee-text-link">Find us on AIBlog.tools</a>
          <a href="https://aijustbetter.com/item/mergeanuke.online" target="_blank" rel="noopener" title="Merge a Nuke Guide: Detailed review, analysis and comparison on AI Just Better">
            <img src="https://cdn.aijustbetter.com/badges/badge-dark.svg" alt="Featured on AIJustBetter.com" width="212" height="55" />
          </a>
        </div>
        <div class="marquee-group" aria-hidden="true">
          <a href="https://aijustbetter.com/item/mergeanuke.online" target="_blank" rel="noopener" title="Merge a Nuke Guide: Detailed review, analysis and comparison on AI Just Better">
            <img src="https://cdn.aijustbetter.com/badges/badge-dark.svg" alt="Featured on AIJustBetter.com" width="212" height="55" />
          </a>
          <a href="https://aiblog.tools" target="_blank" class="marquee-text-link">Find us on AIBlog.tools</a>
          <a href="https://aijustbetter.com/item/mergeanuke.online" target="_blank" rel="noopener" title="Merge a Nuke Guide: Detailed review, analysis and comparison on AI Just Better">
            <img src="https://cdn.aijustbetter.com/badges/badge-dark.svg" alt="Featured on AIJustBetter.com" width="212" height="55" />
          </a>
        </div>
      </div>
    </div>
  </div>

  <style>
    .footer-marquee-section {
      border-top: 1px solid var(--line);
      padding: 24px 0 12px;
      margin-top: 40px;
      overflow: hidden;
      width: 100%;
    }

    .marquee-label {
      font-family: var(--font-display);
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 16px;
      text-align: center;
      opacity: 0.8;
    }

    .marquee-container {
      display: flex;
      overflow: hidden;
      user-select: none;
      gap: 40px;
      mask-image: linear-gradient(
        to right,
        rgba(0, 0, 0, 0) 0%,
        rgba(0, 0, 0, 1) 15%,
        rgba(0, 0, 0, 1) 85%,
        rgba(0, 0, 0, 0) 100%
      );
      -webkit-mask-image: linear-gradient(
        to right,
        rgba(0, 0, 0, 0) 0%,
        rgba(0, 0, 0, 1) 15%,
        rgba(0, 0, 0, 1) 85%,
        rgba(0, 0, 0, 0) 100%
      );
    }

    .marquee-track {
      display: flex;
      flex-shrink: 0;
      align-items: center;
      justify-content: space-around;
      min-width: 100%;
      gap: 40px;
      animation: marquee-scroll 25s linear infinite;
    }

    .marquee-track:hover {
      animation-play-state: paused;
    }

    .marquee-group {
      display: flex;
      align-items: center;
      justify-content: space-around;
      flex-shrink: 0;
      gap: 40px;
    }

    .marquee-group a {
      display: inline-block;
      transition: transform 0.2s ease;
    }

    .marquee-group a:hover {
      transform: scale(1.03);
    }

    .marquee-text-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 55px;
      padding: 0 24px;
      background: rgba(30, 37, 53, 0.4);
      border: 1px dashed var(--line);
      border-radius: var(--radius-interactive);
      color: var(--text);
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 0.85rem;
      white-space: nowrap;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      transition: var(--transition-smooth);
    }

    .marquee-text-link:hover {
      border-color: var(--color-yellow);
      color: var(--color-yellow);
      box-shadow: 0 0 15px rgba(255, 165, 2, 0.15);
      background: rgba(30, 37, 53, 0.6);
      transform: scale(1.03) !important;
    }

    @keyframes marquee-scroll {
      0% {
        transform: translateX(0%);
      }
      100% {
        transform: translateX(-50%);
      }
    }
  </style>

  <div class="footer-bottom">
    <p class="footer-copyright">
      &copy; 2026 {siteConfig.siteName}. All rights reserved. Not affiliated with Roblox Corporation or Nuke The Game developers.
    </p>
  </div>
</footer>
