---
import { siteConfig } from "../data/config";
import { getAvailableLocales, getMainNavItems } from "../lib/navigation";

const navItems = getMainNavItems();
const locales = getAvailableLocales();
const brandInitials = siteConfig.gameName
  .split(/\s+/)
  .filter(Boolean)
  .filter((word) => !["a", "an", "the"].includes(word.toLowerCase()))
  .map((word) => word[0])
  .join("")
  .slice(0, 2)
  .toUpperCase();
---

<header class="site-header">
  <a class="brand" href="/">
    <span class="brand-mark">{brandInitials}</span>
    <span>
      <strong>{siteConfig.siteName}</strong>
      <small>Astro Roblox wiki hub</small>
    </span>
  </a>
  <nav aria-label="Main navigation">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
  <details class="language-menu">
    <summary>Language</summary>
    <div class="language-list">
      {locales.map((item) => (
        <a href={item.completed ? item.href : "#"} aria-disabled={item.completed ? "false" : "true"}>
          {item.label}{item.completed ? "" : " · pending"}
        </a>
      ))}
    </div>
  </details>
</header>
