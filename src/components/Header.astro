---
// input: siteConfig configurations, locales list, navigation items
// output: Main navigation bar component with language selectors and brand initials
// pos: src/components/Header.astro (更新规则：文件变更需同步本注释与所属目录 README)

import { siteConfig } from "../data/config";
import { getAvailableLocales, getMainNavItems } from "../lib/navigation";

const navItems = getMainNavItems();
const locales = getAvailableLocales();
const brandInitials = siteConfig.gameName
  .split(/\s+/)
  .filter(Boolean)
  .filter((word) => !["a", "an", "the"].includes(word.toLowerCase()))
  .map((word) => word[0])
  .join("")
  .slice(0, 2)
  .toUpperCase();
---

<header class="site-header" data-site-header>
  <nav class="site-nav" aria-label="Primary navigation">
    <a class="brand" href="/" aria-label={`${siteConfig.siteName} home`}>
      <span class="brand-mark" aria-hidden="true">{brandInitials}</span>
      <span class="brand-text">
        <strong>{siteConfig.siteName}</strong>
        <small>Roblox Guide</small>
      </span>
    </a>
    <div class="nav-scroll" role="list">
      {navItems.map((item) => (
        <div class="nav-item" role="listitem">
          <a class="nav-link" href={item.href}>
            <span>{item.label}</span>
          </a>
        </div>
      ))}
    </div>
    <div class="site-actions" aria-label="Site actions">
      <details class="language-menu">
        <summary>
          <span>Language</span>
        </summary>
        <div class="language-list">
          {locales.map((item) => (
            <a href={item.completed ? item.href : "#"} aria-disabled={item.completed ? "false" : "true"}>
              {item.label}{item.completed ? "" : " · pending"}
            </a>
          ))}
        </div>
      </details>
    </div>
  </nav>
</header>
