{
  "name": "mergeanuke-online",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/generate-favicons.mjs && astro build && node scripts/generate-seo-files.mjs",
    "preview": "astro preview",
    "init:new-site": "node scripts/init-new-site.mjs",
    "audit:new-site": "node scripts/audit-new-site.mjs",
    "validate:template": "node scripts/validate-template.mjs",
    "validate:static-export": "node scripts/validate-static-export.mjs",
    "indexnow:submit": "node scripts/indexnow-submit.mjs",
    "indexnow:dry-run": "node scripts/indexnow-submit.mjs --dry-run",
    "release:check": "node scripts/release-check.mjs",
    "test": "node --test tests/*.test.mjs",
    "check": "npm run audit:new-site && npm run validate:template && npm test && npm run build && npm run validate:static-export"
  },
  "dependencies": {
    "astro": "^5.0.0",
    "typescript": "^5.7.2"
  }
}
